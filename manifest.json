{
  "manifest_version": 3,
  "name": "Guia de Erros Fiscais",
  "version": "1.0.1",
  "description": "Base de conhecimento de erros fiscais do IXC Provedor. Busque e cadastre erros com um clique.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://restapi-fiscal.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "visual/icon.png",
      "48": "visual/icon.png",
      "128": "visual/logo.png"
    }
  },
  "icons": {
    "16": "visual/icon.png",
    "48": "visual/icon.png",
    "128": "visual/logo.png"
  }
}
